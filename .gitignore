```gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
venv/
ENV/
env/

# UV package manager
.uv/
uv.lock

# Environment variables
*.env
.env.*
!.env.example

# FastAPI / Uvicorn
*.log
logs/
uvicorn.log

# SQLite / local databases
*.db
*.sqlite3

# Alembic migrations cache
alembic.ini.backup
migrations/__pycache__/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# MyPy / Ruff / Lint
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*.bak
*.tmp

# OS files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Docker
docker-compose.override.yml
*.pid

# Secrets / certificates
*.pem
*.key
*.crt

# Uploaded files / media
uploads/
media/
staticfiles/

# Temporary files
tmp/
temp/

# Logs
*.out
*.err


# Local config
config.local.py
settings.local.py
```
